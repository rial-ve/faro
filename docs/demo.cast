[2.007, "o", "\r\n\u001b[1;36mв”Ѓв”Ѓ 1. The store starts empty в”Ѓв”Ѓ\u001b[0m\r\n"]
[1.207, "o", "\u001b[2m$\u001b[0m curl -s http://127.0.0.1:8765/v1/persons | jq\r\n"]
[0.644, "o", "\u001b[1;39m[]\u001b[0m\r\n"]
[1.809, "o", "\r\n\u001b[1;36mв”Ѓв”Ѓ 2. Try recognizing Rodolfo BEFORE enrolling him в”Ѓв”Ѓ\u001b[0m\r\n"]
[1.207, "o", "\u001b[1;33m# expect: no match, 'No reconozco a esta persona.'\u001b[0m\r\n"]
[0.612, "o", "\u001b[2m$\u001b[0m curl -s -X POST http://127.0.0.1:8765/v1/recognize -F 'language=es' -F 'image=@test_data/yo3.jpg' | jq '{match, spoken}'\r\n"]
[0.945, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"match\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;90mnull\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"spoken\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"No reconozco a esta persona.\"\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
[1.808, "o", "\r\n\u001b[1;36mв”Ѓв”Ѓ 3. Enroll Rodolfo using yo3.jpg в”Ѓв”Ѓ\u001b[0m\r\n"]
[1.222, "o", "\u001b[2m$\u001b[0m curl -s -X POST http://127.0.0.1:8765/v1/persons -F 'name=Rodolfo Campos' -F 'description=tu hijo mayor' -F 'image=@test_data/yo3.jpg' | jq '{id, name, description}'\r\n"]
[0.953, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"52d228b49e27\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Rodolfo Campos\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"tu hijo mayor\"\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
[1.807, "o", "\r\n\u001b[1;36mв”Ѓв”Ѓ 4. Recognize again with the SAME photo в”Ѓв”Ѓ\u001b[0m\r\n"]
[1.224, "o", "\u001b[1;33m# expect: high similarity, LLM-phrased Spanish cue\u001b[0m\r\n"]
[0.612, "o", "\u001b[2m$\u001b[0m curl -s -X POST http://127.0.0.1:8765/v1/recognize -F 'language=es' -F 'image=@test_data/yo3.jpg' | jq '{spoken, similarity: .match.similarity}'\r\n"]
[4.391, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"spoken\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Ese es Rodolfo Campos, tu hijo mayor.\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"similarity\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m1.0\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
[1.807, "o", "\r\n\u001b[1;36mв”Ѓв”Ѓ 5. Try a DIFFERENT photo of the same person (yo.jpg) в”Ѓв”Ѓ\u001b[0m\r\n"]
